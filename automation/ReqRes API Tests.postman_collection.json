  "item": [
    {
      "name": "Get single user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"User ID is 2\", function () {\r",
              "    pm.expect(jsonData.data.id).to.eql(2);\r",
              "});\r",
              "\r",
              "pm.test(\"Email exists\", function () {\r",
              "    pm.expect(jsonData.data.email).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"First name exists\", function () {\r",
              "    pm.expect(jsonData.data.first_name).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Last name exists\", function () {\r",
              "    pm.expect(jsonData.data.last_name).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Avatar exists\", function () {\r",
              "    pm.expect(jsonData.data.avatar).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"ID is Number\", function () {\r",
              "    pm.expect(jsonData.data.id).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Status text is OK\", function () {\r",
              "    pm.expect(pm.response.status).to.eql(\"OK\");\r",
              "});\r",
              ""
            ],
